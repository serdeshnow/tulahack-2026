{
  "name": "tulahack-2026-frontend",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "dev:mock": "vite --mode mock",
    "build": "tsc -b && vite build",
    "test": "vitest run --configLoader runner",
    "test:watch": "vitest --configLoader runner",
    "test:ui": "vitest --ui",
    "test:cov": "vitest --coverage",
    "lint": "eslint .",
    "lint:adapter": "eslint ./src/adapter",
    "lint:application": "eslint ./src/application",
    "lint:library": "eslint ./src/library",
    "lint:types": "tsc",
    "preview": "vite preview",
    "format": "prettier --write ./src",
    "generate-api": "swagger-typescript-api generate --path ./public/data/openapi.${FORMAT:-yml} -o ./src/adapter/types -n dto-${CUSTOMER:-tulahack}.ts --no-client --type-prefix Dto"
  },
  "dependencies": {
