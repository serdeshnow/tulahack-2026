# Required secrets
TULA_API_X_TOKEN=replace-with-random-token
TULA_SIGNING_SECRET=replace-with-random-signing-secret

# Optional upstream auth
LMSTUDIO_COOKIE=
LMSTUDIO_API_KEY=

# Docker Compose database credentials
POSTGRES_DB=tula_ml
POSTGRES_USER=tula
POSTGRES_PASSWORD=replace-with-strong-password

# Local runtime defaults
TULA_DATABASE_BACKEND=sqlite
TULA_OBJECT_STORE_BACKEND=local
TULA_RUNTIME_DIR=.runtime